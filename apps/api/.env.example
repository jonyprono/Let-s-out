DATABASE_URL="postgresql://letsout:letsout_secret@localhost:5432/letsout"
REDIS_URL="redis://localhost:6379"

NODE_ENV="development"
PORT=3001
LOG_LEVEL="info"

COOKIE_SECRET="change-me-in-production"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="30d"

CORS_ORIGIN="http://localhost:3000"

# ─── Firebase Admin SDK (Vérification OTP SMS côté backend) ───────────────────
# Obtenir depuis : Firebase Console → Paramètres du projet → Comptes de service
# → Générer une nouvelle clé privée (fichier JSON)
FIREBASE_PROJECT_ID="let-s-out"
FIREBASE_CLIENT_EMAIL=""          # serviceAccountKey.json → client_email
FIREBASE_PRIVATE_KEY=""           # serviceAccountKey.json → private_key (avec \n)

# ─── Meta WhatsApp Cloud API (Envoi OTP via WhatsApp) ────────────────────────
# Obtenir depuis : developers.facebook.com → Mon app → WhatsApp → Prise en main
WHATSAPP_PHONE_ID=""              # Phone Number ID (ex: 123456789012345)
WHATSAPP_ACCESS_TOKEN=""          # Token d'accès permanent (via System User) ou temporaire
WHATSAPP_TEMPLATE_NAME="auth_otp" # Nom du template approuvé dans Meta Business Manager
WHATSAPP_TEMPLATE_LANG="fr"       # Code langue du template (fr, en_US, etc.)

# ─── Resend (Email OTP) — laisser vide en dev → OTP affiché dans les logs ────
# Obtenir depuis : resend.com → API Keys
RESEND_API_KEY=""

# ─── Africa's Talking (SMS fallback) ─────────────────────────────────────────
AT_API_KEY=""
AT_USERNAME=""
AT_SENDER_ID=""

# ─── Cloudflare R2 (Stockage médias) ─────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="letsout-media"
R2_PUBLIC_URL=""

# URL publique de l'API (pour les liens d'upload)
PUBLIC_API_URL="http://localhost:3001"

# ─── Stripe (legacy) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── FedaPay (Paiements Afrique) ──────────────────────────────────────────────
# Obtenir depuis : fedapay.com → Tableau de bord → API
FEDAPAY_SECRET_KEY=""
FEDAPAY_PUBLIC_KEY=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
