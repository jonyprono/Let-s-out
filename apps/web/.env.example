VITE_API_URL=http://localhost:3001/api/v1
VITE_WS_URL=ws://localhost:3001
VITE_STRIPE_PUBLIC_KEY=

# For network access, use .env.local instead and configure with your local IP
# Example for network access:
# VITE_API_URL=http://192.168.1.100:3001/api/v1
# VITE_WS_URL=ws://192.168.1.100:3001
#
# Run: pnpm setup-network (from root)
# This will automatically detect your IP and create .env.local with the correct values

