{
  "name": "lets-out",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "npm@10.8.1",
  "scripts": {
    "preinstall": "node -e \"if(process.env.SKIP_PREINSTALL)process.exit(0); require('child_process').execSync('npx -y pnpm@9.15.4 install', {stdio:'inherit', env: {...process.env, SKIP_PREINSTALL: '1'}})\"",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "setup-network": "node setup-network.js",
    "db:up": "docker-compose -f infra/docker-compose.yml up -d",
    "db:down": "docker-compose -f infra/docker-compose.yml down",
    "db:studio": "pnpm --filter api prisma studio",
    "db:migrate": "pnpm --filter api prisma migrate dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}