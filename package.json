{
  "name": "lets-out",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "npm@10.8.1",
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json'));if(!p.packageManager)process.exit(0);delete p.packageManager;fs.writeFileSync('package.json',JSON.stringify(p,null,2));require('child_process').execSync('npx -y pnpm@9 install', {stdio:'inherit'});\"",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "setup-network": "node setup-network.js",
    "db:up": "docker-compose -f infra/docker-compose.yml up -d",
    "db:down": "docker-compose -f infra/docker-compose.yml down",
    "db:studio": "pnpm --filter api prisma studio",
    "db:migrate": "pnpm --filter api prisma migrate dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}